{
  "name": "@jacobii/layout",
  "version": "1.0.0",
  "description": "Layout components for building easy web apps layouts",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./style": "./dist/style.css"
  },
  "scripts": {
    "build": "rollup -c --bundleConfigAsCjs",
    "test": "echo \"Error: no test specified\" && exit 1",
    "lint": "eslint src --ext .ts,.tsx",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "clean": "rm -rf dist"
  },
  "author": "Samuel Slávik",
  "license": "ISC",
  "files": [
    "dist"
  ],
  "keywords": [
    "layout",
    "react",
    "jacobii"
  ],
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@jacobii/hooks": "1.0.0"
  },
  "devDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tslib": "^2.8.1",
    "typescript": "^5.8.2"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  }
}